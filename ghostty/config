font-family =JetBrainsMonoNL Nerd Font Propo 
mouse-hide-while-typing=true
window-padding-x = 1
window-padding-balance = true
window-vsync = true
theme = Dark Modern
confirm-close-surface=false
working-directory=inherit
window-inherit-working-directory=true
gtk-tabs-location = hidden
gtk-toolbar-style = flat
window-decoration = none
focus-follows-mouse = true
quit-after-last-window-closed = true
keybind = ctrl+alt+t=new_tab
keybind = ctrl+alt+l=next_tab
keybind = ctrl+alt+h=previous_tab
keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = ctrl+alt+w=close_surface
keybind = global:ctrl+shift+alt+t=toggle_quick_terminal
shell-integration = detect
auto-update = off
