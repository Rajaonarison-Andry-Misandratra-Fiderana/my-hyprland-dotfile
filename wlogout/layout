          {
        "label": "update",
        "action": "sudo pacman -Syu",
        "text": "Update",
        "keybind": "u"
    },
    {
        "label": "lock",
        "action": "sh ~/.config/hypr/scripts/update-hyprlock.sh && hyprlock",
        "text": "Lock",
        "keybind": "l"
    },


    {
        "label": "suspend",
        "action": "systemctl suspend",
        "text": "Suspend",
        "keybind": "s"
    },

    {
        "label": "reboot",
        "action": "systemctl reboot",
        "text": "Reboot",
        "keybind": "r"
    },

    {
        "label": "shutdown",
        "action": "systemctl poweroff",
        "text": "Shutdown",
        "keybind": "h"
    }
